# Supabase (required)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key     # ⚠ CRITICAL: currently MISSING from .env, backend falls back to anon key

# Backend
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,https://cloud.vinkspace.fun
VITE_API_URL=http://localhost:8000/api/v1

# Redis (required for Celery + pipeline)
REDIS_URL=redis://user:password@host:6379

# AI — DeepSeek via OpenRouter (OpenAI-compatible SDK)
OPENAI_API_KEY=your_openrouter_api_key                  # DeepSeek/OpenRouter key used via OpenAI SDK
OPENROUTER_API_KEY=your_openrouter_api_key               # same value, kept for clarity

# Meta/WhatsApp (required)
META_ACCESS_TOKEN=your_meta_access_token
META_WABA_ID=your_whatsapp_business_account_id
META_VERIFY_TOKEN=your_webhook_verify_token
META_APP_SECRET=your_meta_app_secret        # ⚠ Required for webhook HMAC verification — get from Meta Developer Dashboard → App Settings → Basic

# Admin
ADMIN_EMAILS=admin@example.com

# Error tracking (optional)
SENTRY_DSN=your_sentry_dsn
